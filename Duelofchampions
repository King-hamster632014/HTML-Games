<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2-Player Arena RPG</title>
    <style>
        body {
            background-color: #121212;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        #game-container {
            background-color: #1e1e1e;
            width: 700px;
            padding: 25px;
            border: 3px solid #333;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
        }
        h1 {
            text-align: center;
            color: #ffffff;
            margin-top: 0;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        #turn-indicator {
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 20px;
            padding: 10px;
            border-radius: 5px;
            transition: background-color 0.3s;
        }
        .p1-turn { background-color: #0d47a1; color: white; }
        .p2-turn { background-color: #b71c1c; color: white; }
        
        #arenas {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 20px;
        }
        .player-card {
            flex: 1;
            padding: 15px;
            border-radius: 8px;
            background-color: #2c2c2c;
        }
        .p1-card { border-top: 5px solid #2196f3; }
        .p2-card { border-top: 5px solid #f44336; }
        
        .health-bar-container {
            width: 100%;
            height: 20px;
            background-color: #000;
            border-radius: 10px;
            overflow: hidden;
            margin-top: 10px;
            border: 1px solid #444;
        }
        .health-bar {
            height: 100%;
            transition: width 0.3s ease-in-out;
        }
        #p1-health-bar { background-color: #2196f3; width: 100%; }
        #p2-health-bar { background-color: #f44336; width: 100%; }

        .stats {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            font-weight: bold;
        }

        #battle-log {
            background-color: #000;
            height: 150px;
            padding: 15px;
            border: 1px solid #444;
            border-radius: 5px;
            margin-bottom: 20px;
            overflow-y: auto;
            font-family: 'Courier New', Courier, monospace;
            line-height: 1.5;
        }

        #controls {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 10px;
        }
        button {
            padding: 15px;
            background-color: #333;
            color: white;
            border: 2px solid #555;
            border-radius: 5px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
        }
        button:hover:not(:disabled) { background-color: #555; }
        button:active:not(:disabled) { transform: scale(0.98); }
        button:disabled { opacity: 0.5; cursor: not-allowed; }
        
        .btn-attack { border-color: #e67e22; }
        .btn-heavy { border-color: #c0392b; }
        .btn-heal { border-color: #27ae60; }
    </style>
</head>
<body>

    <div id="game-container">
        <h1>⚔️ Duel of Champions ⚔️</h1>
        
        <div id="turn-indicator" class="p1-turn">Player 1's Turn</div>

        <div id="arenas">
            <div class="player-card p1-card">
                <h2>Player 1 (Blue)</h2>
                <div class="health-bar-container">
                    <div id="p1-health-bar"></div>
                </div>
                <div class="stats">
                    <span>HP: <span id="p1-hp">150</span>/150</span>
                    <span>Potions: <span id="p1-potions">3</span></span>
                </div>
            </div>

            <div class="player-card p2-card">
                <h2>Player 2 (Red)</h2>
                <div class="health-bar-container">
                    <div id="p2-health-bar"></div>
                </div>
                <div class="stats">
                    <span>HP: <span id="p2-hp">150</span>/150</span>
                    <span>Potions: <span id="p2-potions">3</span></span>
                </div>
            </div>
        </div>

        <div id="battle-log">
            Welcome to the Arena! Player 1, choose your first move.
        </div>

        <div id="controls">
            <button class="btn-attack" onclick="quickAttack()">Quick Attack<br><small>(90% Hit, 10-20 Dmg)</small></button>
            <button class="btn-heavy" onclick="heavyAttack()">Heavy Attack<br><small>(60% Hit, 25-40 Dmg)</small></button>
            <button class="btn-heal" id="btn-heal" onclick="heal()">Drink Potion<br><small>(Restores 30-40 HP)</small></button>
        </div>
        
        <button id="btn-restart" style="width: 100%; display: none; margin-top: 10px;" onclick="restartGame()">Play Again</button>
    </div>

    <script>
        // Player Data
        let p1 = { name: "Player 1", hp: 150, maxHp: 150, potions: 3, color: "#2196f3" };
        let p2 = { name: "Player 2", hp: 150, maxHp: 150, potions: 3, color: "#f44336" };
        let currentPlayer = 1; // 1 for P1, 2 for P2
        let gameActive = true;

        // DOM Elements
        const logBox = document.getElementById("battle-log");
        const turnIndicator = document.getElementById("turn-indicator");
        const btnHeal = document.getElementById("btn-heal");
        const btnRestart = document.getElementById("btn-restart");
        const controls = document.getElementById("controls");

        function logMessage(msg, color = "#e0e0e0") {
            logBox.innerHTML += `<br><span style="color: ${color}">> ${msg}</span>`;
            logBox.scrollTop = logBox.scrollHeight;
        }

        function updateUI() {
            // Update Text
            document.getElementById("p1-hp").innerText = p1.hp;
            document.getElementById("p1-potions").innerText = p1.potions;
            document.getElementById("p2-hp").innerText = p2.hp;
            document.getElementById("p2-potions").innerText = p2.potions;

            // Update Health Bars
            document.getElementById("p1-health-bar").style.width = (p1.hp / p1.maxHp * 100) + "%";
            document.getElementById("p2-health-bar").style.width = (p2.hp / p2.maxHp * 100) + "%";

            // Update Turn Indicator
            if (gameActive) {
                turnIndicator.innerText = `${currentPlayer === 1 ? p1.name : p2.name}'s Turn`;
                turnIndicator.className = currentPlayer === 1 ? "p1-turn" : "p2-turn";
                
                // Disable heal button if current player is out of potions
                let activePlayerObj = currentPlayer === 1 ? p1 : p2;
                btnHeal.disabled = activePlayerObj.potions <= 0;
            }
        }

        function switchTurn() {
            if (!gameActive) return;
            currentPlayer = currentPlayer === 1 ? 2 : 1;
            updateUI();
        }

        function checkWin() {
            if (p1.hp <= 0) {
                p1.hp = 0;
                endGame(p2);
            } else if (p2.hp <= 0) {
                p2.hp = 0;
                endGame(p1);
            }
        }

        function endGame(winner) {
            gameActive = false;
            updateUI();
            turnIndicator.innerText = `${winner.name} WINS!`;
            turnIndicator.style.backgroundColor = "#ffeb3b";
            turnIndicator.style.color = "#000";
            logMessage(`🏆 ${winner.name} is victorious!`, "#ffeb3b");
            controls.style.display = "none";
            btnRestart.style.display = "block";
        }

        // Actions
        function quickAttack() {
            if (!gameActive) return;
            let attacker = currentPlayer === 1 ? p1 : p2;
            let defender = currentPlayer === 1 ? p2 : p1;

            let hitChance = Math.random() * 100;
            if (hitChance <= 90) { // 90% accuracy
                let damage = Math.floor(Math.random() * 11) + 10; // 10 to 20 damage
                defender.hp -= damage;
                logMessage(`${attacker.name} lands a quick strike for ${damage} damage!`, attacker.color);
            } else {
                logMessage(`${attacker.name}'s quick strike missed!`, "#95a5a6");
            }
            
            checkWin();
            switchTurn();
        }

        function heavyAttack() {
            if (!gameActive) return;
            let attacker = currentPlayer === 1 ? p1 : p2;
            let defender = currentPlayer === 1 ? p2 : p1;

            let hitChance = Math.random() * 100;
            if (hitChance <= 60) { // 60% accuracy
                let damage = Math.floor(Math.random() * 16) + 25; // 25 to 40 damage
                defender.hp -= damage;
                logMessage(`${attacker.name} lands a CRUSHING blow for ${damage} damage!`, attacker.color);
            } else {
                logMessage(`${attacker.name} swings wildly and misses entirely!`, "#95a5a6");
            }
            
            checkWin();
            switchTurn();
        }

        function heal() {
            if (!gameActive) return;
            let attacker = currentPlayer === 1 ? p1 : p2;

            if (attacker.potions > 0) {
                let healAmount = Math.floor(Math.random() * 11) + 30; // 30 to 40 heal
                attacker.hp = Math.min(attacker.maxHp, attacker.hp + healAmount);
                attacker.potions--;
                logMessage(`${attacker.name} drinks a potion and recovers ${healAmount} HP.`, "#2ecc71");
                switchTurn();
            }
        }

        function restartGame() {
            p1.hp = p1.maxHp;
            p1.potions = 3;
            p2.hp = p2.maxHp;
            p2.potions = 3;
            currentPlayer = 1;
            gameActive = true;
            
            logBox.innerHTML = "Welcome back to the Arena! Player 1, choose your first move.";
            controls.style.display = "grid";
            btnRestart.style.display = "none";
            
            updateUI();
        }

        // Initialize game
        updateUI();
    </script>
</body>
</html>
