<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Arras.io Trainer - Fixed Stats</title>
    <style>
        body { margin: 0; overflow: hidden; background: #1a1a1a; font-family: sans-serif; color: white; user-select: none; }
        #ui { position: absolute; top: 15px; left: 15px; pointer-events: none; text-shadow: 1px 1px 2px #000; }
        #stats-menu { position: absolute; bottom: 15px; left: 15px; background: rgba(0,0,0,0.7); padding: 15px; border-radius: 8px; border: 1px solid #444; }
        .stat-row { margin: 8px 0; font-size: 14px; font-weight: bold; }
        kbd { background: #555; padding: 2px 6px; border-radius: 3px; font-size: 12px; border-bottom: 2px solid #222; }
        .bar-bg { display: inline-block; width: 100px; height: 12px; background: #333; margin-left: 10px; vertical-align: middle; border-radius: 2px; overflow: hidden; }
        .bar-fill { height: 100%; background: #00B2E1; transition: width 0.2s; }
        #hp-container { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); width: 300px; height: 20px; background: #333; border: 2px solid #555; }
        #hp-fill { width: 100%; height: 100%; background: #85e37d; }
    </style>
</head>
<body>
    <div id="ui">
        <h3 id="class-name">Class: Twin</h3>
        <p>Score: <span id="score">0</span> | Points Available: <span id="points" style="color: #ffeb3b; font-size: 1.2em;">0</span></p>
        <p><kbd>1-5</kbd> Change Class | <kbd>E</kbd> Auto-Fire</p>
    </div>

    <div id="hp-container"><div id="hp-fill"></div></div>

    <div id="stats-menu">
        <div class="stat-row"><kbd>M</kbd> Movement Speed: <span id="s-move">0</span> <div class="bar-bg"><div id="b-move" class="bar-fill" style="width:0%"></div></div></div>
        <div class="stat-row"><kbd>R</kbd> Reload Rate: <span id="s-reload">0</span> <div class="bar-bg"><div id="b-reload" class="bar-fill" style="width:0%"></div></div></div>
        <div class="stat-row"><kbd>B</kbd> Bullet Speed: <span id="s-bullet">0</span> <div class="bar-bg"><div id="b-bullet" class="bar-fill" style="width:0%"></div></div></div>
    </div>

    <canvas id="gameCanvas"></canvas>

<script>
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

// Game State
let score = 0, skillPoints = 0, lastFire = 0;
let isAutoFire = false;
const keys = {}, bullets = [], enemies = [];
const worldSize = 3000;

// Stats
const stats = { move: 0, reload: 0, bullet: 0 };
const maxStat = 10;

const CLASSES = {
    1: { name: "Twin", barrels: [{a: 0, x: 10, y: -10, w: 35, h: 20}, {a: 0, x: 10, y: 10, w: 35, h: 20}], bSpeed: 8, reload: 200, spread: 0.1, bSize: 8 },
    2: { name: "Sniper", barrels: [{a: 0, x: 10, y: 0, w: 50, h: 18}], bSpeed: 15, reload: 900, spread: 0, bSize: 10 },
    3: { name: "Flank Guard", barrels: [{a: 0, x: 10, y: 0, w: 35, h: 20}, {a: Math.PI, x: 10, y: 0, w: 35, h: 20}], bSpeed: 8, reload: 350, spread: 0.1, bSize: 8 },
    4: { name: "Machine Gun", barrels: [{a: 0, x: 10, y: 0, w: 35, h: 25}], bSpeed: 9, reload: 100, spread: 0.4, bSize: 7 },
    5: { name: "Destroyer", barrels: [{a: 0, x: 10, y: 0, w: 40, h: 35}], bSpeed: 5, reload: 1500, spread: 0, bSize: 22 }
};

let currentClass = CLASSES[1];
const player = { 
    x: worldSize / 2, 
    y: worldSize / 2, 
    radius: 22, 
    color: '#00B2E1',
    hp: 100,
    maxHp: 100
};

// Fixed Input Handler
window.addEventListener('keydown', e => {
    keys[e.code] = true;
    
    // Numbers for classes
    if (CLASSES[e.key]) {
        currentClass = CLASSES[e.key];
        document.getElementById('class-name').innerText = "Class: " + currentClass.name;
    }

    if (e.code === 'KeyE') isAutoFire = !isAutoFire;

    // Stat spending - Fixed to use e.code
    if (skillPoints > 0) {
        if (e.code === 'KeyM' && stats.move < maxStat) { stats.move++; skillPoints--; }
        if (e.code === 'KeyR' && stats.reload < maxStat) { stats.reload++; skillPoints--; }
        if (e.code === 'KeyB' && stats.bullet < maxStat) { stats.bullet++; skillPoints--; }
        updateStatUI();
    }
});
window.addEventListener('keyup', e => keys[e.code] = false);

let mouseX = 0, mouseY = 0, isMouseDown = false;
window.addEventListener('mousedown', () => isMouseDown = true);
window.addEventListener('mouseup', () => isMouseDown = false);
window.addEventListener('mousemove', e => { mouseX = e.clientX; mouseY = e.clientY; });

function updateStatUI() {
    document.getElementById('points').innerText = skillPoints;
    ['move', 'reload', 'bullet'].forEach(s => {
        document.getElementById(`s-${s}`).innerText = stats[s];
        document.getElementById(`b-${s}`).style.width = (stats[s] * 10) + "%";
    });
}

function shoot() {
    const reloadBonus = stats.reload * 15;
    const now = Date.now();
    if (now - lastFire < Math.max(50, currentClass.reload - reloadBonus)) return;
    
    const angleToMouse = Math.atan2(mouseY - canvas.height/2, mouseX - canvas.width/2);
    
    currentClass.barrels.forEach(b => {
        const spread = (Math.random() - 0.5) * currentClass.spread;
        const finalAngle = angleToMouse + b.a + spread;
        const bSpeed = currentClass.bSpeed + (stats.bullet * 0.8);
        
        bullets.push({
            x: player.x + Math.cos(finalAngle) * 40,
            y: player.y + Math.sin(finalAngle) * 40,
            vx: Math.cos(finalAngle) * bSpeed,
            vy: Math.sin(finalAngle) * bSpeed,
            radius: currentClass.bSize,
            life: 120
        });
    });
    lastFire = now;
}

function update() {
    // Movement
    const speed = 4 + (stats.move * 0.5);
    if (keys['KeyW']) player.y -= speed;
    if (keys['KeyS']) player.y += speed;
    if (keys['KeyA']) player.x -= speed;
    if (keys['KeyD']) player.x += speed;
    
    if (isMouseDown || isAutoFire) shoot();

    bullets.forEach((b, i) => {
        b.x += b.vx; b.y += b.vy; b.life--;
        if (b.life <= 0) bullets.splice(i, 1);
    });

    enemies.forEach((en, i) => {
        const dx = player.x - en.x, dy = player.y - en.y, dist = Math.hypot(dx, dy);
        en.x += (dx / dist) * 1.5; en.y += (dy / dist) * 1.5;

        // Player collision
        if (dist < player.radius + en.radius) {
            player.hp -= 0.5;
            if (player.hp <= 0) {
                player.x = worldSize/2; player.y = worldSize/2; player.hp = 100;
                score = Math.floor(score/2);
            }
        }

        bullets.forEach((b, bi) => {
            if (Math.hypot(b.x - en.x, b.y - en.y) < en.radius + b.radius) {
                en.health--;
                bullets.splice(bi, 1);
                if (en.health <= 0) {
                    enemies.splice(i, 1);
                    score += 25;
                    if (score % 100 === 0) skillPoints++;
                    document.getElementById('score').innerText = score;
                    document.getElementById('points').innerText = skillPoints;
                }
            }
        });
    });
    
    document.getElementById('hp-fill').style.width = (player.hp/player.maxHp * 100) + "%";

    if (enemies.length < 15 && Math.random() < 0.03) {
        enemies.push({ x: player.x + (Math.random()-0.5)*1500, y: player.y + (Math.random()-0.5)*1500, radius: 20, health: 3 });
    }
}

function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.save();
    ctx.translate(canvas.width/2 - player.x, canvas.height/2 - player.y);

    // Draw Grid
    ctx.strokeStyle = '#333';
    for(let i=0; i<=worldSize; i+=50) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, worldSize); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(worldSize, i); ctx.stroke();
    }

    enemies.forEach(en => {
        ctx.fillStyle = '#F14E54'; ctx.beginPath(); ctx.arc(en.x, en.y, en.radius, 0, Math.PI*2); ctx.fill();
        ctx.strokeStyle = '#555'; ctx.lineWidth = 3; ctx.stroke();
    });

    ctx.fillStyle = '#EEE';
    bullets.forEach(b => { ctx.beginPath(); ctx.arc(b.x, b.y, b.radius, 0, Math.PI*2); ctx.fill(); });

    // Player
    ctx.save();
    ctx.translate(player.x, player.y);
    const angle = Math.atan2(mouseY - canvas.height/2, mouseX - canvas.width/2);
    ctx.fillStyle = '#999'; ctx.strokeStyle = '#555';
    currentClass.barrels.forEach(b => {
        ctx.save(); ctx.rotate(angle + b.a); ctx.fillRect(b.x, b.y - b.h/2, b.w, b.h); ctx.strokeRect(b.x, b.y - b.h/2, b.w, b.h); ctx.restore();
    });
    ctx.beginPath(); ctx.arc(0, 0, player.radius, 0, Math.PI*2);
    ctx.fillStyle = player.color; ctx.fill(); ctx.stroke();
    ctx.restore();

    ctx.restore();
    requestAnimationFrame(draw);
}

setInterval(update, 1000/60);
draw();
window.onresize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
</script>
</body>
</html>w
