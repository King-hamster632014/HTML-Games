<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Trading App</title>

<style>
body {
    margin:0;
    font-family: Arial, sans-serif;
    background:#0f172a;
    color:white;
}

/* Header */
.header {
    padding:10px;
    text-align:center;
    background:#020617;
    font-size:18px;
}

/* Tabs */
.tabs {
    display:flex;
    justify-content:space-around;
    background:#1e293b;
}
.tab {
    flex:1;
    padding:10px;
    text-align:center;
    cursor:pointer;
}
.active { background:#334155; }

/* Content */
.content {
    padding:10px;
}

/* Cards */
.card {
    background:#1e293b;
    padding:10px;
    margin-bottom:10px;
    border-radius:10px;
}

/* Buttons */
button {
    padding:8px;
    margin:3px;
    border:none;
    border-radius:6px;
    font-size:14px;
}
.buy { background:#22c55e; }
.sell { background:#ef4444; }

/* Chart */
canvas {
    width:100%;
    height:200px;
    background:#020617;
    border-radius:10px;
}

/* Responsive */
@media(min-width:700px){
    .content { max-width:600px; margin:auto; }
}
</style>
</head>

<body>

<div class="header">
📈 Trading App | <span id="stats"></span>
</div>

<div class="tabs">
<div class="tab active" onclick="showTab('market')">Market</div>
<div class="tab" onclick="showTab('chart')">Chart</div>
<div class="tab" onclick="showTab('portfolio')">Portfolio</div>
</div>

<div class="content">

<div id="market"></div>

<div id="chartView" style="display:none;">
<canvas id="chart"></canvas>
</div>

<div id="portfolio" style="display:none;"></div>

</div>

<script>
let cash=10000;
let selected="Bitcoin";

let assets={
Bitcoin:{price:30000, owned:0, history:[]},
Ethereum:{price:2000, owned:0, history:[]},
Tesla:{price:250, owned:0, history:[]}
};

function showTab(tab){
    document.getElementById("market").style.display="none";
    document.getElementById("chartView").style.display="none";
    document.getElementById("portfolio").style.display="none";

    document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));

    if(tab==="market"){
        document.getElementById("market").style.display="block";
        document.querySelectorAll(".tab")[0].classList.add("active");
    }
    if(tab==="chart"){
        document.getElementById("chartView").style.display="block";
        document.querySelectorAll(".tab")[1].classList.add("active");
    }
    if(tab==="portfolio"){
        document.getElementById("portfolio").style.display="block";
        document.querySelectorAll(".tab")[2].classList.add("active");
    }
}

function updatePrices(){
    for(let k in assets){
        let a=assets[k];
        a.price *= (1 + (Math.random()-0.5)*0.03);
        a.price=Math.max(1,a.price);

        a.history.push(a.price);
        if(a.history.length>40) a.history.shift();
    }
}

function drawChart(){
    let canvas=document.getElementById("chart");
    let ctx=canvas.getContext("2d");

    canvas.width=canvas.offsetWidth;
    canvas.height=200;

    ctx.clearRect(0,0,canvas.width,canvas.height);

    let h=assets[selected].history;
    if(h.length<2) return;

    let max=Math.max(...h);
    let min=Math.min(...h);

    ctx.strokeStyle="#38bdf8";
    ctx.beginPath();

    h.forEach((p,i)=>{
        let x=i*(canvas.width/h.length);
        let y=canvas.height-((p-min)/(max-min))*180;
        if(i===0) ctx.moveTo(x,y);
        else ctx.lineTo(x,y);
    });

    ctx.stroke();
}

function render(){
    let total=cash;

    let mHTML="", pHTML="";

    for(let k in assets){
        let a=assets[k];
        total += a.owned*a.price;

        mHTML+=`
        <div class="card" onclick="selected='${k}'">
        <b>${k}</b><br>
        $${a.price.toFixed(2)}<br>
        <button class="buy" onclick="event.stopPropagation(); buy('${k}')">Buy</button>
        <button class="sell" onclick="event.stopPropagation(); sell('${k}')">Sell</button>
        </div>
        `;

        pHTML+=`
        <div class="card">
        ${k}: ${a.owned}
        </div>
        `;
    }

    document.getElementById("market").innerHTML=mHTML;
    document.getElementById("portfolio").innerHTML=pHTML;

    document.getElementById("stats").innerText =
        `Cash $${cash.toFixed(0)} | Net $${total.toFixed(0)}`;

    drawChart();
}

function buy(k){
    let a=assets[k];
    if(cash>=a.price){
        a.owned++;
        cash-=a.price;
    }
}

function sell(k){
    let a=assets[k];
    if(a.owned>0){
        a.owned--;
        cash+=a.price;
    }
}

// Save system
function save(){
    localStorage.setItem("mobileTrading", JSON.stringify({cash,assets}));
}
function load(){
    let d=JSON.parse(localStorage.getItem("mobileTrading"));
    if(d){cash=d.cash; assets=d.assets;}
}

load();

setInterval(()=>{
    updatePrices();
    save();
    render();
},1500);

render();
</script>

</body>
</html>
